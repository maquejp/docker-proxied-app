# Docker Proxied App Environment Configuration

# Application Environment
NODE_ENV=production
BACKEND_PORT=3000

# Frontend Configuration
FRONTEND_URL=https://localhost:8095

# Oracle Database Configuration
ORACLE_SERVER=your-oracle-server.com
ORACLE_PORT=1521
ORACLE_USERNAME=your_db_username
ORACLE_PASSWORD=your_db_password
ORACLE_DATABASE=your_database_name
ORACLE_POOL_MIN=2
ORACLE_POOL_MAX=10
ORACLE_POOL_INCREMENT=1

# JWT Configuration (CHANGE THESE IN PRODUCTION!)
JWT_SECRET=your-super-secure-jwt-secret-key-at-least-32-chars-long
JWT_EXPIRES_IN=10h
JWT_REFRESH_EXPIRES_IN=7d

# API Rate Limiting
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX=100

# Docker Configuration
COMPOSE_PROJECT_NAME=docker-proxied-app

# SSL/TLS Configuration (optional)
# SSL_CERT_PATH=/path/to/certificate.crt
# SSL_KEY_PATH=/path/to/private.key

# Monitoring and Logging
# LOG_LEVEL=info
# SENTRY_DSN=your-sentry-dsn (optional)

# Development Only (do not use in production)
# DEBUG=true
# MOCK_ORACLE=true