# Dependencies
**/node_modules
**/npm-debug.log*
**/yarn-debug.log*
**/yarn-error.log*

# Build artifacts
**/dist
**/build

# Environment files
**/.env
**/.env.local
**/.env.production

# Logs
**/logs
**/*.log

# Runtime data
**/pids
**/*.pid
**/*.seed
**/*.pid.lock

# Coverage
**/coverage
**/nyc_output

# IDE and editor files
**/.vscode
**/.idea
**/*.swp
**/*.swo
**/*~

# OS files
**/.DS_Store
**/Thumbs.db

# Git
**/.git
**/.gitignore

# Testing
**/test-results
**/playwright-report

# Documentation
**/README.md
**/docs
**/*.md

# Development files
**/src/**/*.spec.ts
**/src/**/*.test.ts
**/.eslintrc.*
**/.prettierrc
**/tsconfig.json
**/angular.json
**/karma.conf.js

# Temporary files
**/tmp
**/temp

# Package manager files (except package.json and lock files)
**/.npm
**/.yarn
**/yarn.lock
**/package-lock.json

# Keep only necessary files for production build
!**/package.json
!**/yarn.lock
!**/package-lock.json