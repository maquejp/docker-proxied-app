# Docker Proxied App - Environment Variables
# Copy this file to .env and configure your environment

# Application Configuration
NODE_ENV=development
BACKEND_PORT=3000
FRONTEND_URL=http://localhost:4200

# Oracle Database Configuration
ORACLE_SERVER=localhost
ORACLE_PORT=1521
ORACLE_USER=docker_app_user
ORACLE_PASSWORD=docker_app_password
ORACLE_SERVICE=XE
ORACLE_DATABASE=XE
ORACLE_CONNECT_STRING=localhost:1521/XE

# Database Connection Pool Settings
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_POOL_INCREMENT=1
DB_POOL_TIMEOUT=60
DB_STMT_CACHE_SIZE=30
DB_QUEUE_TIMEOUT=60000
DB_POOL_PING_INTERVAL=60

# Oracle Client Configuration (optional)
# ORACLE_CLIENT_LIB_DIR=/path/to/oracle/instantclient
# ORACLE_CONFIG_DIR=/path/to/oracle/config

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=10h
JWT_REFRESH_EXPIRES_IN=7d

# API Configuration
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX=100

# Logging Configuration
LOG_LEVEL=info
LOG_FORMAT=json